APP_NAME=ParfumeriaWebshop
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.buttercupperfumery.local

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=webshop_db
DB_USERNAME=webshop
DB_PASSWORD=

# Frontend origin (used by config/cors.php)
FRONTEND_URL=https://buttercupperfumery.local

# Redis — backs queue, cache, sessions in production
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# Sanctum
# Comma-separated list of stateful SPA domains (no scheme, include port if non-default)
SANCTUM_STATEFUL_DOMAINS=buttercupperfumery.local
# Token lifetime in minutes (20160 = 14 days)
SANCTUM_EXPIRATION=20160

# Mail (transactional) — swap driver/creds when the provider is chosen.
#
# Tested provider snippets (uncomment ONE block + fill in the secrets):
#
#   MAILGUN
#   MAIL_MAILER=smtp
#   MAIL_HOST=smtp.eu.mailgun.org      # or smtp.mailgun.org for US region
#   MAIL_PORT=587
#   MAIL_USERNAME=postmaster@mg.buttercupperfumery.com
#   MAIL_PASSWORD=
#   MAIL_ENCRYPTION=tls
#
#   POSTMARK
#   MAIL_MAILER=postmark
#   POSTMARK_TOKEN=
#
#   SENDGRID (SMTP relay)
#   MAIL_MAILER=smtp
#   MAIL_HOST=smtp.sendgrid.net
#   MAIL_PORT=587
#   MAIL_USERNAME=apikey               # literal string "apikey"
#   MAIL_PASSWORD=                     # the SendGrid API key
#   MAIL_ENCRYPTION=tls
#
#   AWS SES (region-specific endpoint)
#   MAIL_MAILER=ses
#   AWS_ACCESS_KEY_ID=
#   AWS_SECRET_ACCESS_KEY=
#   AWS_DEFAULT_REGION=eu-central-1
#
# Default block (SMTP placeholders — replace with your provider above):
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@buttercupperfumery.local"
MAIL_FROM_NAME="${APP_NAME}"

# Analytics tracking key — generate with: php -r "echo base64_encode(random_bytes(32));"
# NEVER reuse the dev key. This file is committed; real value belongs in the host's .env.
TRACKING_API_KEY=

# Sentry (error monitoring) — paste the Laravel DSN from sentry.io here
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Seed admin credentials (only used by AdminSeeder when APP_ENV=local|testing).
# Intentionally blank here — production admin is created via `php artisan make:admin`.
SEED_ADMIN_PASSWORD=
