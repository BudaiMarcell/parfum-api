APP_NAME=ParfumeriaWebshop
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=webshop_db
DB_USERNAME=
DB_PASSWORD=

CACHE_STORE=database

SESSION_DRIVER=database
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost:5173

TRACKING_API_KEY=

# Mail (local) — `log` writes mails to storage/logs/laravel.log. Switch
# to `smtp` and fill in MAIL_HOST / MAIL_USERNAME / MAIL_PASSWORD when
# wiring a real provider. See .env.production.example for the prod set.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@buttercupperfumery.local"
MAIL_FROM_NAME="${APP_NAME}"

# Where to bounce the user after they click the verification link.
FRONTEND_URL=http://localhost:5173

# Local dev uses `sync` so mailables are sent inline (no worker needed).
# Production overrides this to `redis` in .env.production.example.
QUEUE_CONNECTION=sync